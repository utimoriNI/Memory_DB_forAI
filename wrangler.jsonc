{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-memory-admin",
  "main": "src/admin/worker.ts",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "apps/mobile-admin/public",
    "binding": "ASSETS"
  },
  "vars": {
    "GITHUB_OWNER": "utimorini",
    "GITHUB_REPOSITORY": "Memory_DB_forAI",
    "GITHUB_BRANCH": "main"
  }
}
