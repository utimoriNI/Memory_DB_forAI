# Required: absolute or project-relative path to the AI Memory Vault.
MEMORY_VAULT_PATH=./memory

# Optional: absolute path to a human-managed Obsidian vault (read-only).
OBSIDIAN_VAULT_PATH=

LOG_LEVEL=info
PINNED_MEMORY_WARNING_LIMIT=20
MAX_CONTEXT_FILES=20
MAX_CONTEXT_CHARACTERS=50000

# Used only by the optional daily GitHub Actions Inbox extraction workflow.
# Keep the real value in GitHub Actions Secrets; never commit it here.
MEMORY_DAILY_OPENAI_MODEL=gpt-5.4-mini
